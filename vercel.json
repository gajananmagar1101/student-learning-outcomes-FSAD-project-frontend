{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd student-platform && npm install",
  "buildCommand": "cd student-platform && npm run build",
  "outputDirectory": "student-platform/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
